QUANT_APP_NAME=AlphaAgent
QUANT_APP_ENV=dev
QUANT_API_V1_PREFIX=/api/v1
# Structured JSON logging (per design doc §7.1.1). Set QUANT_LOG_FORMAT=text for plain text.
QUANT_LOG_LEVEL=INFO
QUANT_LOG_FORMAT=json
QUANT_SERVICE_NAME=quant-api
QUANT_DEFAULT_CURRENCY=CNY
QUANT_SIMULATED_TRADING=true
QUANT_MARKET_DATA_PROVIDER=mock
# Supported values: mock, akshare, auto
QUANT_DATABASE_URL=sqlite:///./var/quant.db
QUANT_DATABASE_ECHO=false
QUANT_SEED_DEMO_DATA=true

# Authentication (set QUANT_AUTH_ENABLED=true in production)
QUANT_AUTH_ENABLED=false
QUANT_ADMIN_API_KEY=dev-admin-key
QUANT_TRADER_API_KEY=dev-trader-key
QUANT_VIEWER_API_KEY=dev-viewer-key

# Signal model
QUANT_SIGNAL_MODEL_VERSION=technical_v1

# Default paper-trading account
QUANT_DEFAULT_ACCOUNT_ID=acct-demo-001

# LLM Analysis (keyword fallback works without any key)
# Supported providers: keyword, openai, deepseek, qwen, ollama
QUANT_LLM_PROVIDER=keyword
QUANT_LLM_MODEL=
QUANT_LLM_API_KEY=
QUANT_LLM_BASE_URL=
QUANT_LLM_TEMPERATURE=0.2
QUANT_LLM_TIMEOUT=30
# DeepSeek example:
#   QUANT_LLM_PROVIDER=deepseek
#   QUANT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# Qwen example:
#   QUANT_LLM_PROVIDER=qwen
#   QUANT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# Ollama local example:
#   QUANT_LLM_PROVIDER=ollama
#   QUANT_LLM_MODEL=qwen2.5:7b

# CORS (comma-separated origins, * = open). Credentials are disabled by default.
QUANT_CORS_ORIGINS=*

# External notification channels (all optional)
# Webhook: 飞书 / 钉钉 / Slack / 自定义
QUANT_NOTIFY_WEBHOOK_URL=
QUANT_NOTIFY_WEBHOOK_FORMAT=generic   # generic | feishu | dingtalk | slack
# Email (SMTP)
QUANT_NOTIFY_SMTP_HOST=
QUANT_NOTIFY_SMTP_PORT=465
QUANT_NOTIFY_SMTP_USER=
QUANT_NOTIFY_SMTP_PASSWORD=
QUANT_NOTIFY_SMTP_TLS=true
QUANT_NOTIFY_EMAIL_TO=
