QUANT_APP_NAME=AlphaAgent
QUANT_APP_ENV=dev
QUANT_API_V1_PREFIX=/api/v1
# Structured JSON logging (per design doc §7.1.1). Set QUANT_LOG_FORMAT=text for plain text.
QUANT_LOG_LEVEL=INFO
QUANT_LOG_FORMAT=json
QUANT_SERVICE_NAME=quant-api
QUANT_DEFAULT_CURRENCY=CNY
QUANT_SIMULATED_TRADING=true
QUANT_MARKET_DATA_PROVIDER=mock
# Supported values: mock, akshare, auto
QUANT_DATABASE_URL=sqlite:///./var/quant.db
QUANT_DATABASE_ECHO=false
QUANT_SEED_DEMO_DATA=true

# Authentication defaults to enabled in code. This example disables auth for local dev only.
QUANT_AUTH_ENABLED=false
QUANT_ADMIN_API_KEY=dev-admin-key
QUANT_TRADER_API_KEY=dev-trader-key
QUANT_VIEWER_API_KEY=dev-viewer-key

# Signal model
QUANT_SIGNAL_MODEL_VERSION=technical_v1

# Default paper-trading account
QUANT_DEFAULT_ACCOUNT_ID=acct-demo-001

# LLM Analysis (keyword fallback works without any key)
# Supported providers: keyword, openai, deepseek, qwen, ollama
QUANT_LLM_PROVIDER=keyword
QUANT_LLM_MODEL=
QUANT_LLM_API_KEY=
QUANT_LLM_BASE_URL=
QUANT_LLM_TEMPERATURE=0.2
QUANT_LLM_TIMEOUT=30
# DeepSeek example:
#   QUANT_LLM_PROVIDER=deepseek
#   QUANT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# Qwen example:
#   QUANT_LLM_PROVIDER=qwen
#   QUANT_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# Ollama local example:
#   QUANT_LLM_PROVIDER=ollama
#   QUANT_LLM_MODEL=qwen2.5:7b

# CORS (comma-separated origins). Use * only for isolated local development.
QUANT_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000

# Auto evolution sampling. Defaults are conservative: background scanner sampling
# and auto LLM review are off unless explicitly enabled.
QUANT_EVOLUTION_VALIDATE_INTERVAL_SECONDS=86400
QUANT_EVOLUTION_VALIDATE_INITIAL_DELAY_SECONDS=60
QUANT_EVOLUTION_VALIDATE_LIMIT=200
# Optional fixed local-server validation time. Empty = use interval mode.
# Example: QUANT_EVOLUTION_VALIDATE_TIME=15:30
QUANT_EVOLUTION_VALIDATE_TIME=
# Send Feishu alerts when unattended validation/evolution or sampling fails.
QUANT_EVOLUTION_FAILURE_ALERT_ENABLED=true
QUANT_EVOLUTION_FAILURE_ALERT_COOLDOWN_SECONDS=3600
QUANT_EVOLUTION_AUTO_SCAN_ENABLED=false
QUANT_EVOLUTION_AUTO_SCAN_INTERVAL_SECONDS=86400
QUANT_EVOLUTION_AUTO_SCAN_TOP_N=20
QUANT_EVOLUTION_AUTO_SCAN_MIN_SCORE=50
QUANT_EVOLUTION_AUTO_SCAN_CANDIDATE_POOL=100
QUANT_EVOLUTION_AUTO_SCAN_ENABLE_FUNDAMENTAL=true
QUANT_EVOLUTION_AUTO_SCAN_ENABLE_LLM=false
QUANT_EVOLUTION_AUTO_SCAN_LLM_TOP_N=8
QUANT_EVOLUTION_AUTO_SCAN_TARGET_HORIZON_DAYS=0

# External notification channels (all optional)
# 飞书 Webhook can also be saved from Settings at runtime.
QUANT_FEISHU_WEBHOOK_URL=
# Email (SMTP)
QUANT_NOTIFY_SMTP_HOST=
QUANT_NOTIFY_SMTP_PORT=465
QUANT_NOTIFY_SMTP_USER=
QUANT_NOTIFY_SMTP_PASSWORD=
QUANT_NOTIFY_SMTP_TLS=true
QUANT_NOTIFY_EMAIL_TO=
