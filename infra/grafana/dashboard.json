{
  "annotations": {"list": []},
  "description": "Quant Trading Platform — operational overview. Scrapes /api/v1/metrics/prom (Prometheus exposition).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Orders — Total",
      "targets": [{"expr": "quant_orders_total", "refId": "A"}],
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Orders — Pending",
      "targets": [{"expr": "quant_orders_pending"}],
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 50},
            {"color": "red", "value": 200}
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Orders — Filled",
      "targets": [{"expr": "quant_orders_filled"}],
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0}
    },
    {
      "type": "stat",
      "title": "Orders — Cancelled",
      "targets": [{"expr": "quant_orders_cancelled"}],
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "title": "Risk Events — Blocked",
      "targets": [{"expr": "quant_risk_events_blocked"}],
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 1},
            {"color": "red", "value": 10}
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Audit Logs",
      "targets": [{"expr": "quant_audit_logs_total"}],
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Order rate (rate per minute)",
      "targets": [
        {"expr": "rate(quant_orders_total[5m]) * 60", "legendFormat": "all", "refId": "A"},
        {"expr": "rate(quant_orders_filled[5m]) * 60", "legendFormat": "filled", "refId": "B"},
        {"expr": "rate(quant_orders_cancelled[5m]) * 60", "legendFormat": "cancelled", "refId": "C"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "type": "timeseries",
      "title": "Signals & recommendations rate",
      "targets": [
        {"expr": "rate(quant_signals_total[5m]) * 60", "legendFormat": "signals", "refId": "A"},
        {"expr": "rate(quant_recommendations_total[5m]) * 60", "legendFormat": "recs", "refId": "B"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "type": "stat",
      "title": "WS subscribers — quotes",
      "targets": [{"expr": "quant_ws_subscribers_quotes"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 12}
    },
    {
      "type": "stat",
      "title": "WS subscribers — alerts",
      "targets": [{"expr": "quant_ws_subscribers_alerts"}],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 12}
    },
    {
      "type": "stat",
      "title": "WS subscribers — advisor",
      "targets": [{"expr": "quant_ws_subscribers_advisor"}],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 12}
    },
    {
      "type": "gauge",
      "title": "KV Cache — hit rate",
      "targets": [{"expr": "quant_kv_cache_hit_rate"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 0.4},
            {"color": "green", "value": 0.8}
          ]}
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 12}
    },
    {
      "type": "timeseries",
      "title": "Per-fn market cache hit rate",
      "targets": [
        {"expr": "quant_market_cache_hits / (quant_market_cache_hits + quant_market_cache_misses)",
         "legendFormat": "{{fn}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["quant", "trading"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Quant Platform Overview",
  "uid": "quant-overview",
  "version": 1,
  "weekStart": ""
}
